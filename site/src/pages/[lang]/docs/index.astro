---
import Base from '../../../layouts/Base.astro';
import LanguagePicker from '../../../components/LanguagePicker.astro';
import DocSidebar from '../../../components/DocSidebar.astro';
import Footer from '../../../components/Footer.astro';
import { languages, type Lang } from '../../../i18n/ui';
import { t } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---
<Base title={`${t(lang, 'nav_docs')} — Tetora`} lang={lang}>
  <LanguagePicker currentLang={lang} basePath="/docs/" />
  <nav style="padding:50px 20px 0;max-width:1100px;margin:0 auto;font-size:13px;color:var(--muted)">
    <a href="/" style="color:var(--muted)">&larr; {t(lang, 'nav_home')}</a> / {t(lang, 'nav_docs')}
  </nav>
  <div class="doc-layout">
    <DocSidebar lang={lang} />
    <article>
      <h1>{t(lang, 'nav_docs')}</h1>
      <p style="color:var(--muted);margin-top:16px">Select a topic from the sidebar to get started.</p>
    </article>
  </div>
  <Footer />
</Base>
