---
import PostLayout from '../../../layouts/PostLayout.astro';
import { languages } from '../../../i18n/ui';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const tips = await getCollection('tips');
  return tips.map(tip => {
    const lang = tip.data.lang;
    const slug = tip.id.split('/').slice(1).join('/');
    return {
      params: { lang, slug },
      props: { tip },
    };
  });
}

const { tip } = Astro.props;
const { Content } = await render(tip);
const lang = tip.data.lang;
const slug = tip.id.split('/').slice(1).join('/');
---
<PostLayout
  title={tip.data.title}
  lang={lang}
  date={tip.data.date}
  tag="tips"
  slug={slug}
  section="tips"
>
  <h1>{tip.data.title}</h1>
  <div class="article-meta">{tip.data.date}</div>
  <Content />
</PostLayout>
